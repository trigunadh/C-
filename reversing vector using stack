#include<iostream>
#include<vector>
#include<stack>
using namespace std;
void reverse(vector<int> &vect)
{
    stack<int>s;
    for(int i=0;i<vect.size();i++)
     s.push(vect[i]);
     for(int i=0;i<vect.size();i++)
     {vect[i]=s.top();
     s.pop();
     }
}
int main()
{
    vector< int> vect={1,2,3,4,5,6};
    for(int i=0;i<vect.size();i++)
    {
        cout<<vect[i];
    }
    cout<<endl;
    reverse(vect);
    for(int i=0;i<vect.size();i++)
    {
        cout<<vect[i];
    }
    return 0;
    
}
