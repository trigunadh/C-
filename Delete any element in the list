#include<iostream>
using namespace std;
struct Node{
	int data;
	Node* next;
};
class linkedlist{
	private:
		Node* head;
	public:
		linkedlist(){
			head=NULL;
		}
		void display(){
			Node* temp=head;
			while (temp!=NULL) {
				cout<<temp->data<<"->";
				temp=temp->next;
			}
			cout<<"END\n";
		}
		void insert(int value) {
			Node* newNode=new Node();
			newNode->data=value;
			newNode->next=head;
			head=newNode;
		}
		void deleteAny(int pos){
			if(head==NULL) return;
			Node* temp=head;
			if(pos==0){
				head=head->next;
				delete temp;
				return;
			}
			for(int i=0;i<pos-1 && temp!=NULL;i++){
				temp=temp->next;
			}
			if(temp==NULL || temp->next==NULL) return;
			Node* del=temp->next;
			temp->next=temp->next->next;
			delete del;
		}
};
int main(){
	linkedlist L1;
	L1.insert(6);
	L1.insert(15);
	L1.insert(64);
	L1.display();
	L1.deleteAny(1);
	L1.display();
	return 0;
}

